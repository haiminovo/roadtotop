{
  "name": "roadtotop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -s first \"pnpm dev:web\" \"pnpm dev:ws\"",
    "dev:web": "next dev --turbopack",
    "dev:ws": "node --watch server/start-websocket.js",
    "start:web": "next start",
    "start:ws": "node server/start-websocket.js",
    "db:init": "node server/init-db.js",
    "build": "next build",
    "start": "concurrently -k -s first \"pnpm start:web\" \"pnpm start:ws\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "antd": "^6.3.7",
    "dotenv": "^17.4.2",
    "next": "15.3.3",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "redis": "^5.12.1",
    "websocket": "^1.0.35"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
